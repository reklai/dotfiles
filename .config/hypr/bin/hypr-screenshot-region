#!/bin/sh
set -eu

missing=""
for cmd in grim slurp wl-copy; do
	if ! command -v "$cmd" >/dev/null 2>&1; then
		missing="$missing $cmd"
	fi
done

if [ -n "$missing" ]; then
	notify-send -a "Noctalia" -u critical -t 5000 "Screenshot" "Missing tools:$missing"
	exit 1
fi

dir="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
mkdir -p "$dir"

file="$dir/screenshot-$(date +%Y%m%d-%H%M%S).png"
geometry="$(slurp)" || exit 0

[ -n "$geometry" ] || exit 0

grim -g "$geometry" "$file"
wl-copy --type image/png < "$file"
notify-send -a "Noctalia" -u low -t 2500 "Screenshot" "Saved and copied"
